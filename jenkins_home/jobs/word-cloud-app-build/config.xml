  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition" plugin="workflow-cps@4285.v8df38f05c3c5">
    <scm class="hudson.plugins.git.GitSCM" plugin="git@5.10.1">
